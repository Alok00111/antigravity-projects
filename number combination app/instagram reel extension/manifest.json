{
  "manifest_version": 3,
  "name": "Instagram Reel Downloader & Twitter Scheduler",
  "description": "Download Instagram reels with one click and schedule them to Twitter",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "http://localhost:3847/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": [
        "content/instagram.js"
      ],
      "css": [
        "content/instagram.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content/twitter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://fastdl.app/*",
        "https://www.fastdl.app/*"
      ],
      "js": [
        "content/fastdl.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Reel Downloader"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ]
    }
  ]
}