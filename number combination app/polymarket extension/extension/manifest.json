{
  "manifest_version": 3,
  "name": "Polymarket Real-Data Scraper",
  "version": "1.0",
  "description": "Scrapes real live market data from Polymarket and sends to local backend.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://polymarket.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}